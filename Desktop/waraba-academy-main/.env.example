# ==================================
# Waraba Academy - Variables d'Environnement
# ==================================

# Supabase (REQUIS)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-anon-key
SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
# URL publique du site (production) — utilisée par SEO, sitemap, emails
NEXT_PUBLIC_SITE_URL=https://waraba-academy.com
NODE_ENV=development

# Stripe (pour les paiements)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Wave (paiement mobile money direct via l'API Wave Business)
# Récupérer sur https://business.wave.com → Developers → API Keys
# Format : wave_sn_prod_XXXXXXXXXX  (prod)  ou  wave_sn_uat_XXXXXXXXXX  (test)
WAVE_API_KEY=wave_sn_prod_...
# Secret de signature webhook (portail Wave Business → Developers → Webhooks → Secret)
WAVE_WEBHOOK_SECRET=whsec_...


# Resend (emails transactionnels + marketing)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Waraba Academy <noreply@waraba-academy.com>

# Resend Audience ID — liste marketing (dashboard Resend > Audiences > copier l'ID)
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Email de l'équipe qui reçoit les messages de contact
CONTACT_NOTIFICATION_EMAIL=contact@waraba-academy.com

# URL du guide PDF gratuit (LeadMagnet) — héberger le fichier et coller l'URL ici
LEAD_MAGNET_GUIDE_URL=https://waraba-academy.com/guide.pdf

# Sécurité (optionnel)
JWT_SECRET=votre-jwt-secret-32-caracteres-min
BCRYPT_SALT_ROUNDS=12

# Rate Limiting (optionnel)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Features (optionnel)
ENABLE_REGISTRATION=true
ENABLE_PAYMENTS=true
ENABLE_ANALYTICS=false
ENABLE_NOTIFICATIONS=true

# Logging (optionnel)
LOG_LEVEL=info
